{
  "name": "story-agent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "uv run --project apps/api uvicorn story_agent_api.main:app --reload --host 127.0.0.1 --port 8000",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "test": "npm run test:api && npm run test:web",
    "test:api": "uv run --project apps/api pytest apps/api/tests",
    "test:web": "npm --prefix apps/web run test",
    "test:e2e": "npm --prefix apps/web run test:e2e"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
